{
  "name": "claudaborative-editing",
  "version": "0.1.1",
  "description": "MCP server for collaborative WordPress post editing via Yjs CRDT",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "claudaborative-editing": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "license": "GPL-2.0-or-later",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pento/claudaborative-editing.git"
  },
  "keywords": [
    "mcp",
    "wordpress",
    "gutenberg",
    "collaborative-editing",
    "yjs",
    "claude"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint --max-warnings 0 'src/**/*.ts' 'tests/**/*.ts' '**/*.md' && markdownlint-cli2 '**/*.md' '#node_modules'",
    "lint:fix": "eslint --fix --max-warnings 0 'src/**/*.ts' 'tests/**/*.ts' '**/*.md' && markdownlint-cli2 --fix '**/*.md' '#node_modules'",
    "format": "prettier --write 'src/**/*.ts' 'tests/**/*.ts' '*.config.*' '*.json' '.*.jsonc' '*.md'",
    "format:check": "prettier --check 'src/**/*.ts' 'tests/**/*.ts' '*.config.*' '*.json' '.*.jsonc' '*.md'",
    "prepublishOnly": "npm run typecheck && npm run lint && npm test && npm run build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@wordpress/block-serialization-default-parser": "^5.42.0",
    "lib0": "0.2.99",
    "y-protocols": "^1.0.7",
    "yjs": "13.6.29",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@eslint/markdown": "^7.5.1",
    "@types/node": "^22.19.15",
    "@vitest/coverage-v8": "^4.1.0",
    "@wordpress/env": "^11.2.0",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "markdownlint-cli2": "^0.22.0",
    "prettier": "^3.8.1",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.1",
    "vitest": "^4.1.0"
  }
}
