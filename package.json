{
  "name": "claudaborative-editing",
  "version": "0.1.1",
  "description": "MCP server for collaborative WordPress post editing via Yjs CRDT",
  "type": "module",
  "main": "dist/index.js",
  "exports": {
    ".": "./dist/index.js"
  },
  "sideEffects": false,
  "author": "Gary Pendergast",
  "bin": {
    "claudaborative-editing": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "license": "GPL-2.0-or-later",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pento/claudaborative-editing.git"
  },
  "keywords": [
    "mcp",
    "wordpress",
    "gutenberg",
    "collaborative-editing",
    "yjs",
    "claude"
  ],
  "engines": {
    "node": ">=20.19"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "eslint --max-warnings 0 . && markdownlint-cli2 && prettier --check -u .",
    "lint:fix": "eslint --fix --max-warnings 0 . && markdownlint-cli2 --fix && prettier --write -u .",
    "prepare": "husky",
    "prepublishOnly": "npm run typecheck && npm run lint && npm test && npm run build",
    "start": "node dist/index.js",
    "test": "vitest run",
    "pretest:e2e": "npm run build",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:install": "playwright install chromium",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "lint-staged": {
    "*.{ts,js,md,json,jsonc}": "prettier --write",
    "*.{ts,js}": "eslint --max-warnings 0",
    "*.md": [
      "eslint --max-warnings 0",
      "markdownlint-cli2"
    ]
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@wordpress/block-serialization-default-parser": "^5.42.0",
    "lib0": "0.2.99",
    "y-protocols": "^1.0.7",
    "yjs": "13.6.29",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@eslint/markdown": "^7.5.1",
    "@playwright/test": "^1.58.2",
    "@types/node": "^22.19.15",
    "@vitest/coverage-v8": "^4.1.0",
    "@wordpress/env": "^11.2.0",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-package-json": "^0.91.0",
    "husky": "^9.1.7",
    "jiti": "^2.6.1",
    "lint-staged": "^16.4.0",
    "markdownlint-cli2": "^0.22.0",
    "prettier": "^3.8.1",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.1",
    "vitest": "^4.1.0"
  }
}
