{
	"name": "claudaborative-editing",
	"version": "0.4.1",
	"description": "MCP server for collaborative WordPress post editing via Yjs CRDT",
	"type": "module",
	"main": "dist/index.js",
	"exports": {
		".": "./dist/index.js",
		"./prompts/definitions": "./dist/prompts/definitions.js",
		"./prompts/prompt-content": "./dist/prompts/prompt-content.js",
		"./prompts/registry": "./dist/prompts/registry.js",
		"./server-instructions": "./dist/server-instructions.js",
		"./session/session-manager": "./dist/session/session-manager.js",
		"./shared/commands": "./dist/shared/commands.js",
		"./tools/definitions": "./dist/tools/definitions.js",
		"./tools/registry": "./dist/tools/registry.js"
	},
	"sideEffects": false,
	"author": "Gary Pendergast",
	"bin": {
		"claudaborative-editing": "dist/index.js"
	},
	"files": [
		"dist"
	],
	"license": "GPL-2.0-or-later",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/pento/claudaborative-editing.git"
	},
	"keywords": [
		"mcp",
		"wordpress",
		"gutenberg",
		"collaborative-editing",
		"yjs",
		"claude"
	],
	"engines": {
		"node": ">=22.6"
	},
	"packageManager": "npm@11.9.0",
	"scripts": {
		"build": "tsup",
		"build:all": "npm run build && npm --prefix wordpress-plugin run build",
		"check:generated": "npm run generate:defs && git diff --exit-code wordpress-plugin/includes/class-command-defs.php wordpress-plugin/src/utils/command-i18n.ts",
		"dev": "tsup --watch",
		"dev:wp": "NODE_USE_ENV_PROXY=1 wp-playground-cli server --mount-before-install=./wordpress-plugin:/wordpress/wp-content/plugins/claudaborative-editing --blueprint=./playground/dev.blueprint.json --port=9400 --wp=latest --php=8.5",
		"generate:defs": "node bin/generate-shared-defs.js && prettier --write wordpress-plugin/src/utils/command-i18n.ts",
		"lint": "ESLINT_USE_FLAT_CONFIG=true eslint --max-warnings 0 . && npm --prefix wordpress-plugin run lint:style && markdownlint-cli2 && prettier --check -u .",
		"lint:fix": "ESLINT_USE_FLAT_CONFIG=true eslint --fix --max-warnings 0 . && npm --prefix wordpress-plugin run lint:style:fix && markdownlint-cli2 --fix && prettier --write -u .",
		"prepare": "husky && npm run build",
		"prepublishOnly": "npm run typecheck && npm run lint && npm test",
		"start": "node dist/index.js",
		"test": "vitest run",
		"pretest:e2e": "(cd wordpress-plugin && composer install --no-interaction --prefer-dist) && npm run build:all",
		"test:e2e": "playwright test",
		"pretest:e2e:headed": "npm run pretest:e2e",
		"test:e2e:headed": "playwright test --headed",
		"test:e2e:install": "playwright install chromium",
		"test:plugin-js": "npm --prefix wordpress-plugin test",
		"test:plugin-js:coverage": "npm --prefix wordpress-plugin run test:coverage",
		"pretest:plugin-php": "bash wordpress-plugin/bin/fetch-wp-tests-lib.sh && (cd wordpress-plugin && composer install --no-interaction --prefer-dist) && npm --prefix wordpress-plugin run prebuild",
		"test:plugin-php": "NODE_USE_ENV_PROXY=1 wp-playground-cli php --wp=latest --php=8.5 --mount=./wordpress-plugin:/wordpress/wp-content/plugins/claudaborative-editing --mount=./wordpress-plugin/.wp-tests-lib:/wordpress-phpunit --blueprint=./playground/phpunit.blueprint.json --define WP_TESTS_CONFIG_FILE_PATH /wordpress/wp-content/plugins/claudaborative-editing/tests/wp-tests-config.php -- /wordpress/wp-content/plugins/claudaborative-editing/vendor/bin/phpunit -c /wordpress/wp-content/plugins/claudaborative-editing/phpunit.xml.dist",
		"pretest:plugin-php:coverage": "npm run pretest:plugin-php",
		"test:plugin-php:coverage": "NODE_USE_ENV_PROXY=1 wp-playground-cli php --xdebug --wp=latest --php=8.5 --mount=./wordpress-plugin:/wordpress/wp-content/plugins/claudaborative-editing --mount=./wordpress-plugin/.wp-tests-lib:/wordpress-phpunit --blueprint=./playground/phpunit.blueprint.json --define WP_TESTS_CONFIG_FILE_PATH /wordpress/wp-content/plugins/claudaborative-editing/tests/wp-tests-config.php -- /wordpress/wp-content/plugins/claudaborative-editing/vendor/bin/phpunit -c /wordpress/wp-content/plugins/claudaborative-editing/phpunit.xml.dist",
		"test:watch": "vitest",
		"typecheck": "tsc --noEmit"
	},
	"lint-staged": {
		"*.{ts,js,md,json,jsonc}": "prettier --write",
		"*.{ts,js}": "env ESLINT_USE_FLAT_CONFIG=true eslint --max-warnings 0 --no-warn-ignored",
		"*.md": "markdownlint-cli2",
		"wordpress-plugin/src/**/*.scss": "npm --prefix wordpress-plugin run lint:style:fix",
		"wordpress-plugin/**/*.php": [
			"bash -c 'cd wordpress-plugin && (vendor/bin/phpcbf --no-cache || test $? -eq 1)'",
			"bash -c 'cd wordpress-plugin && vendor/bin/phpstan analyse --no-progress --memory-limit=1024M'"
		]
	},
	"dependencies": {
		"@modelcontextprotocol/sdk": "^1.29.0",
		"@wordpress/block-serialization-default-parser": "^5.43.0",
		"lib0": "0.2.99",
		"y-protocols": "^1.0.7",
		"yjs": "13.6.29",
		"zod": "^4.3.6"
	},
	"devDependencies": {
		"@babel/core": "^7.29.0",
		"@eslint/eslintrc": "^2.1.4",
		"@eslint/js": "^8.57.1",
		"@playwright/test": "^1.59.1",
		"@types/eslint__eslintrc": "^2.1.2",
		"@types/eslint__js": "^8.42.3",
		"@types/node": "^25.5.2",
		"@vitest/coverage-v8": "^4.1.2",
		"@wordpress/e2e-test-utils-playwright": "^1.43.0",
		"@wordpress/eslint-plugin": "^24.5.0",
		"@wordpress/prettier-config": "^4.43.0",
		"@wp-playground/cli": "^3.1.20",
		"eslint": "^8.57.1",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-package-json": "^0.91.1",
		"globals": "^17.4.0",
		"husky": "^9.1.7",
		"lint-staged": "^16.4.0",
		"markdownlint-cli2": "^0.22.0",
		"prettier": "^3.8.1",
		"tsup": "^8.5.1",
		"typescript": "~6.0.2",
		"typescript-eslint": "^8.58.0",
		"vitest": "^4.1.2"
	},
	"overrides": {
		"@wordpress/e2e-test-utils-playwright": {
			"@types/node": "$@types/node"
		}
	}
}
