{
	"preset": "@wordpress/jest-preset-default",
	"moduleNameMapper": {
		"^#shared/(.*)$": "<rootDir>/../shared/$1"
	},
	"transform": {
		"\\.[jt]sx?$": "<rootDir>/node_modules/@wordpress/scripts/config/babel-transform.js"
	},
	"collectCoverageFrom": [
		"src/**/*.{ts,tsx}",
		"!src/**/test/**",
		"!src/types/**",
		"!src/**/types.ts"
	],
	"coverageDirectory": "coverage/typescript",
	"coverageReporters": ["text", "lcov"]
}
