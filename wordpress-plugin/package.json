{
	"name": "claudaborative-editing-plugin",
	"version": "0.5.2",
	"description": "WordPress plugin that adds AI action controls to the Gutenberg editor.",
	"private": true,
	"devDependencies": {
		"@resvg/resvg-js": "^2.6.2",
		"@testing-library/react": "^16.3.2",
		"@types/jest": "^29.5.14",
		"@wordpress/api-fetch": "^7.44.0",
		"@wordpress/components": "^32.6.0",
		"@wordpress/compose": "^7.44.0",
		"@wordpress/core-data": "^7.44.0",
		"@wordpress/data": "^10.44.0",
		"@wordpress/editor": "^14.44.0",
		"@wordpress/element": "^6.44.0",
		"@wordpress/i18n": "^6.17.0",
		"@wordpress/icons": "^12.2.0",
		"@wordpress/interface": "^9.29.0",
		"@wordpress/notices": "^5.44.0",
		"@wordpress/plugins": "^7.44.0",
		"@wordpress/scripts": "^32.0.0",
		"react": "^18.3.1",
		"stylelint-config-prettier-scss": "^1.0.0",
		"typescript": "^6.0.3"
	},
	"scripts": {
		"prebuild": "node ../bin/generate-shared-defs.js",
		"build": "wp-scripts build && node bin/build-icons.js",
		"start": "wp-scripts start",
		"test:php": "npm --prefix .. run test:plugin-php",
		"test:php:coverage": "npm --prefix .. run test:plugin-php:coverage",
		"lint:style": "wp-scripts lint-style 'src/**/*.scss'",
		"lint:style:fix": "wp-scripts lint-style 'src/**/*.scss' --fix",
		"test": "wp-scripts test-unit-js",
		"test:coverage": "wp-scripts test-unit-js --coverage",
		"typecheck": "tsc --noEmit"
	}
}
