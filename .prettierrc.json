{
  "singleQuote": true,
  "trailingComma": "all",
  "semi": true,
  "printWidth": 100,
  "useTabs": false,
  "tabWidth": 2,
  "arrowParens": "always",
  "bracketSpacing": true,
  "endOfLine": "lf",
  "overrides": [
    {
      "files": ["*.jsonc", ".*.jsonc"],
      "options": { "trailingComma": "none" }
    },
    {
      "files": ["wordpress-plugin/**/*.{js,css,json}"],
      "options": {
        "useTabs": true,
        "tabWidth": 4,
        "singleQuote": false
      }
    }
  ]
}
