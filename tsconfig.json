{
	"compilerOptions": {
		"target": "ES2022",
		"module": "ES2022",
		"moduleResolution": "bundler",
		"lib": ["ES2022"],
		"types": ["node"],
		"outDir": "dist",
		"strict": true,
		"esModuleInterop": true,
		"skipLibCheck": true,
		"forceConsistentCasingInFileNames": true,
		"resolveJsonModule": true,
		"declaration": true,
		"declarationMap": true,
		"sourceMap": true,
		"isolatedModules": true,
		"noUnusedLocals": true,
		"noUnusedParameters": true,
		"noFallthroughCasesInSwitch": true,
		"paths": {
			"#wordpress/*": ["./src/wordpress/*"],
			"#yjs/*": ["./src/yjs/*"],
			"#session/*": ["./src/session/*"],
			"#tools/*": ["./src/tools/*"],
			"#blocks/*": ["./src/blocks/*"]
		}
	},
	"include": ["src/**/*", "tests/**/*", "*.config.*"],
	"exclude": ["node_modules", "dist"]
}
