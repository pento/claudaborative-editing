{
	"$schema": "https://playground.wordpress.net/blueprint-schema.json",
	"preferredVersions": {
		"php": "8.5",
		"wp": "latest"
	},
	"features": {
		"networking": true
	},
	"steps": [
		{
			"step": "installPlugin",
			"pluginData": {
				"resource": "wordpress.org/plugins",
				"slug": "gutenberg"
			}
		},
		{
			"step": "activatePlugin",
			"pluginPath": "claudaborative-editing/claudaborative-editing.php"
		},
		{
			"step": "setSiteOptions",
			"options": {
				"wp_collaboration_enabled": 1
			}
		}
	]
}
